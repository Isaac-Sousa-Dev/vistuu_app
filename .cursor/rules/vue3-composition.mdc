## 🍍 Pinia — Gerenciamento de Estado

```ts
// stores/user.ts
import { defineStore } from 'pinia'
import { ref, computed } from 'vue'
import type { User } from '@/types/user'

// ✅ Use sempre a Composition Store (setup store)
export const useUserStore = defineStore('user', () => {
  // State
  const user = ref<User | null>(null)
  const isLoading = ref(false)

  // Getters
  const isAuthenticated = computed(() => !!user.value)
  const fullName = computed(() =>
    user.value ? `${user.value.firstName} ${user.value.lastName}` : ''
  )

  // Actions
  async function fetchUser(id: string) {
    isLoading.value = true
    try {
      user.value = await UserService.getById(id)
    } finally {
      isLoading.value = false
    }
  }

  function logout() {
    user.value = null
  }

  return { user, isLoading, isAuthenticated, fullName, fetchUser, logout }
})
```

- **Sempre** use **setup stores** (não options stores).
- Um arquivo de store por domínio; nome do arquivo em `kebab-case`.
- O nome da store (primeiro argumento do `defineStore`) deve ser único e em `camelCase`.
- Nunca acesse a store diretamente fora de componentes ou outros composables — use o hook `use*Store()`.
- Use `storeToRefs()` para desestruturar estado/getters reativos de uma store.
- Persista estado com `pinia-plugin-persistedstate` quando necessário — configure por store, nunca globalmente.

```ts
// ✅ Desestruturação correta
const { user, isLoading } = storeToRefs(useUserStore())
const { fetchUser, logout } = useUserStore() // actions não precisam de storeToRefs
```

